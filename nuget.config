<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!-- Use only the public NuGet feed so the project restores cleanly anywhere
       (ignores any machine-level private feeds). -->
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>
